# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# MP exige back_url https público (localhost não funciona). Em dev local, use a URL da Vercel:
# MP_BACK_URL=https://seu-app.vercel.app

# Legal / LGPD (opcional)
NEXT_PUBLIC_PRIVACY_EMAIL=privacidade@dungeonbox.com.br
NEXT_PUBLIC_SUPPORT_EMAIL=suporte@dungeonbox.com.br
NEXT_PUBLIC_COMPANY_CNPJ=

# Supabase — https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe — checkout transparente (Payment Element) + assinaturas mensais
# Use pk_live_/sk_live_ se os Price IDs forem de produção (livemode).
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_AVENTUREIRO=price_xxx
STRIPE_PRICE_HEROI=price_xxx
STRIPE_PRICE_LENDARIO=price_xxx
# Cupons de desconto no checkout (Promotion Codes do Stripe Dashboard)
NEXT_PUBLIC_STRIPE_COUPONS_ENABLED=true

# Mercado Pago (legado — opcional se ainda houver assinaturas antigas)
NEXT_PUBLIC_MP_PUBLIC_KEY=TEST-xxx
MP_ACCESS_TOKEN=TEST-xxx
MP_WEBHOOK_SECRET=your-webhook-secret

# E-mail (Resend) — roadmap Fase 6
RESEND_API_KEY=re_xxx
EMAIL_FROM=noreply@dungeonbox.com.br
