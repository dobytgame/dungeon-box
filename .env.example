# App — use o domínio canônico em produção (SEO, sitemap, Open Graph, links de e-mail)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Opcional: verificação Google Search Console (meta tag)
# GOOGLE_SITE_VERIFICATION=
# Google Tag Manager (carrega após consentimento de cookies analíticos/marketing)
NEXT_PUBLIC_GTM_ID=GTM-P6RGTX9W
# MP exige back_url https público (localhost não funciona). Em dev local, use a URL da Vercel:
# MP_BACK_URL=https://seu-app.vercel.app

# Legal / LGPD (opcional)
NEXT_PUBLIC_PRIVACY_EMAIL=privacidade@dungeonbox.com.br
NEXT_PUBLIC_SUPPORT_EMAIL=mestre@dungeonbox.com.br
NEXT_PUBLIC_COMPANY_CNPJ=

# Supabase — https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Provedor de pagamento no checkout: asaas (padrão) | stripe
PAYMENT_PROVIDER=asaas
NEXT_PUBLIC_PAYMENT_PROVIDER=asaas

# Asaas — checkout transparente + assinaturas mensais
# Local: escape no $ inicial (dotenv-expand do Next.js). Vercel: cole a chave crua ($aact_...) sem \
ASAAS_API_KEY=\$aact_xxx
ASAAS_WEBHOOK_TOKEN=seu-token-do-webhook-asaas
# sandbox | production (opcional; padrão production)
ASAAS_ENV=sandbox
# Opcional: sobrescreve a URL base da API
# ASAAS_API_URL=https://api-sandbox.asaas.com/v3

# Stripe — legado (mantido para rollback; desativado quando PAYMENT_PROVIDER=asaas)
# Use pk_live_/sk_live_ se os Price IDs forem de produção (livemode).
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_AVENTUREIRO=price_xxx
STRIPE_PRICE_HEROI=price_xxx
STRIPE_PRICE_LENDARIO=price_xxx
# Cupons no site (tabela promo_codes no Supabase) — funciona com Asaas
NEXT_PUBLIC_CHECKOUT_COUPONS_ENABLED=true

# Cupons de desconto no checkout Stripe (Promotion Codes do Dashboard)
NEXT_PUBLIC_STRIPE_COUPONS_ENABLED=true

# Mercado Pago (legado — opcional se ainda houver assinaturas antigas)
NEXT_PUBLIC_MP_PUBLIC_KEY=TEST-xxx
MP_ACCESS_TOKEN=TEST-xxx
MP_WEBHOOK_SECRET=your-webhook-secret

# E-mail (Resend) — todos os endereços no domínio verificado
RESEND_API_KEY=re_xxx
EMAIL_FROM=guilda@dungeonbox.com.br
EMAIL_FROM_MARKETING=taverna@dungeonbox.com.br
EMAIL_FROM_GUILD=guilda@dungeonbox.com.br
EMAIL_FROM_BILLING=tesouro@dungeonbox.com.br
EMAIL_FROM_SUPPORT=mestre@dungeonbox.com.br
EMAIL_FROM_SHIPPING=rastreio@dungeonbox.com.br
EMAIL_FROM_PRODUCTION=forja@dungeonbox.com.br
# Alias legado da newsletter (LP pré-lançamento)
EMAIL_FROM_NEWSLETTER=taverna@dungeonbox.com.br
